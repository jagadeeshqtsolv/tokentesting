      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "step1",
        "action": "openUrl",
        "targetDescription": "Navigate to the admin page",
        "value": "https://qa-atlas.qtsolvdev.com/admin"
      },
      {
        "id": "step2",
        "action": "assertVisible",
