        "assertion": "Admin"
      },
      {
        "id": "step3",
        "action": "assertDisabled",
        "targetDescription": "Verify the admin's Account Access toggle is disabled",
        "locatorHint": "toggle for admin user"
      },
      {
        "id": "step4",
        "action": "hover",
        "targetDescription": "Hover over the admin's disabled toggle",
        "locatorHint": "toggle for admin user"
      },
      {
        "id": "step5",
        "action": "assertVisible",
        "targetDescription": "Verify tooltip 'You cannot revoke your own access.' is displayed",
        "locatorHint": "tooltip element",
        "assertion": "You cannot revoke your own access."
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
