{
  "id": "search-no-results-message",
  "testPlanId": "5f9ff6dc-3f0f-4586-98c6-f172410f59b7",
  "requirementId": "12806486-6b93-422f-a030-d38607b2cdbd",
  "suiteName": "Admin — User Management — Smoke",
  "case": {
    "id": "search-no-results-message",
    "title": "Search with no results shows empty-state message and keeps header visible",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Admin",
        "value": "https://qa-atlas.qtsolvdev.com/admin"
      },
      {
        "id": "s2",
        "action": "tap",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s3",
        "action": "waitForVisible",
        "targetDescription": "Search input",
        "locatorHint": "input[placeholder='Search user']"
      },
      {
        "id": "s4",
        "action": "fill",
        "targetDescription": "Type a non-matching query",
        "locatorHint": "input[placeholder='Search user']",
        "value": "zzznomatch"
      },
      {
        "id": "s5",
        "action": "assertVisible",
        "targetDescription": "Table header row remains visible",
        "locatorHint": "thead"
      },
      {
        "id": "s6",
        "action": "assertContainsText",
        "targetDescription": "No results message visible with query text",
        "locatorHint": "tbody tr td, tbody",
        "assertion": "No users found for 'zzznomatch'."
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
