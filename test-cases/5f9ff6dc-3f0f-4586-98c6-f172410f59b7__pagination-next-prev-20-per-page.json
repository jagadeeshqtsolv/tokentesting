{
  "id": "pagination-next-prev-20-per-page",
  "testPlanId": "5f9ff6dc-3f0f-4586-98c6-f172410f59b7",
  "requirementId": "12806486-6b93-422f-a030-d38607b2cdbd",
  "suiteName": "Admin — User Management — Smoke",
  "case": {
    "id": "pagination-next-prev-20-per-page",
    "title": "Pagination shows 20 rows per page and Next/Previous work when >20 users",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Admin",
        "value": "https://qa-atlas.qtsolvdev.com/admin"
      },
      {
        "id": "s2",
        "action": "tap",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s3",
        "action": "waitForVisible",
        "targetDescription": "User table visible",
        "locatorHint": "table:has(thead)"
      },
      {
        "id": "s4",
        "action": "assertCount",
        "targetDescription": "Page 1 shows 20 rows",
        "locatorHint": "tbody tr"
      },
      {
        "id": "s5",
        "action": "assertVisible",
        "targetDescription": "Pagination controls visible",
        "locatorHint": "[data-testid=pagination]"
      },
      {
        "id": "s6",
        "action": "assertDisabled",
        "targetDescription": "Previous is disabled on first page",
        "locatorHint": "[data-testid=pagination] button:has-text('Previous')"
      },
      {
        "id": "s7",
        "action": "tap",
        "targetDescription": "Click Next",
        "locatorHint": "[data-testid=pagination] button:has-text('Next')"
      },
      {
        "id": "s8",
        "action": "assertEnabled",
        "targetDescription": "Previous is enabled on subsequent page",
        "locatorHint": "[data-testid=pagination] button:has-text('Previous')"
      },
      {
        "id": "s9",
        "action": "assertText",
        "targetDescription": "Active page indicator shows 2",
        "locatorHint": "[data-testid=pagination] [aria-current='page']",
        "assertion": "2"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
