{
  "id": "switch-tabs-roles-and-back",
  "testPlanId": "5f9ff6dc-3f0f-4586-98c6-f172410f59b7",
  "requirementId": "12806486-6b93-422f-a030-d38607b2cdbd",
  "suiteName": "Admin — User Management — Smoke",
  "case": {
    "id": "switch-tabs-roles-and-back",
    "title": "Switch to Roles & Access and back to User Management",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Admin",
        "value": "https://qa-atlas.qtsolvdev.com/admin"
      },
      {
        "id": "s2",
        "action": "tap",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s3",
        "action": "waitForVisible",
        "targetDescription": "User Management tab visible",
        "locatorHint": "[role=tab]:has-text('User Management')"
      },
      {
        "id": "s4",
        "action": "tap",
        "targetDescription": "Click Roles & Access tab",
        "locatorHint": "[role=tab]:has-text('Roles & Access')"
      },
      {
        "id": "s5",
        "action": "assertSelected",
        "targetDescription": "Roles & Access tab is active",
        "locatorHint": "[role=tab][aria-selected=true]:has-text('Roles & Access')"
      },
      {
        "id": "s6",
        "action": "tap",
        "targetDescription": "Click User Management tab",
        "locatorHint": "[role=tab]:has-text('User Management')"
      },
      {
        "id": "s7",
        "action": "assertSelected",
        "targetDescription": "User Management tab is active again",
        "locatorHint": "[role=tab][aria-selected=true]:has-text('User Management')"
      },
      {
        "id": "s8",
        "action": "assertVisible",
        "targetDescription": "User table visible",
        "locatorHint": "table[aria-label='User table'], table:has(thead)"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
