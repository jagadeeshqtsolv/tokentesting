  "suiteName": "Admin User Management Smoke Test",
  "case": {
    "id": "revoke-access",
    "title": "Flow 4 — Revoke account access",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "step1",
        "action": "openUrl",
        "targetDescription": "Navigate to the admin page",
        "value": "https://qa-atlas.qtsolvdev.com/admin"
      },
      {
        "id": "step2",
        "action": "tap",
        "targetDescription": "Click the active user's Account Access toggle (ON state)",
        "locatorHint": "toggle for active user (teal/ON)"
      },
      {
        "id": "step3",
        "action": "assertVisible",
        "targetDescription": "Verify confirmation dialog appears with title 'Revoke access?'",
        "locatorHint": "dialog title",
        "assertion": "Revoke access?"
      },
      {
        "id": "step4",
        "action": "tap",
        "targetDescription": "Click the 'Revoke' button in the dialog",
        "locatorHint": "button with text 'Revoke'"
      },
      {
        "id": "step5",
        "action": "assertVisible",
        "targetDescription": "Verify the toggle indicator changes to OFF (grey)",
        "locatorHint": "toggle for user",
        "assertion": "OFF"
      },
      {
        "id": "step6",
        "action": "assertVisible",
        "targetDescription": "Verify user's Status badge changes to 'Inactive'",
        "locatorHint": "status cell badge",
        "assertion": "Inactive"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
