{
  "id": "pagination",
  "testPlanId": "1e399e6b-cc7f-4522-ad72-67673f3a3181",
  "requirementId": "12806486-6b93-422f-a030-d38607b2cdbd",
  "suiteName": "Admin User Management Smoke Test",
  "case": {
    "id": "pagination",
    "title": "Flow 9 — Pagination when user count exceeds 20",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [
      "Organisation has more than 20 users"
    ],
    "steps": [
      {
        "id": "step1",
        "action": "openUrl",
        "targetDescription": "Navigate to the admin page with >20 users",
        "value": "https://qa-atlas.qtsolvdev.com/admin"
      },
      {
        "id": "step2",
        "action": "assertCount",
        "targetDescription": "Verify that 20 user rows are displayed on page 1",
        "locatorHint": "user table row"
      },
      {
        "id": "step3",
        "action": "assertVisible",
        "targetDescription": "Verify pagination controls are visible below the table",
        "locatorHint": "pagination controls",
        "assertion": "Previous, Next"
      },
      {
        "id": "step4",
        "action": "tap",
        "targetDescription": "Click the 'Next' button to navigate to page 2",
        "locatorHint": "button with text 'Next'"
      },
      {
        "id": "step5",
        "action": "assertCount",
        "targetDescription": "Verify that user rows for page 2 are displayed",
        "locatorHint": "user table row"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
