{
  "id": "admin-default-user-management-ui",
  "testPlanId": "5f9ff6dc-3f0f-4586-98c6-f172410f59b7",
  "requirementId": "12806486-6b93-422f-a030-d38607b2cdbd",
  "suiteName": "Admin — User Management — Smoke",
  "case": {
    "id": "admin-default-user-management-ui",
    "title": "Admin /admin loads with User Management as default, tabs in order, header and columns render",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Admin",
        "value": "https://qa-atlas.qtsolvdev.com/admin"
      },
      {
        "id": "s2",
        "action": "tap",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s3",
        "action": "waitForVisible",
        "targetDescription": "Tablist visible",
        "locatorHint": "[role=tablist]"
      },
      {
        "id": "s4",
        "action": "assertText",
        "targetDescription": "Tab 1 label",
        "locatorHint": "[role=tablist] [role=tab]:nth-child(1)",
        "assertion": "User Management"
      },
      {
        "id": "s5",
        "action": "assertText",
        "targetDescription": "Tab 2 label",
        "locatorHint": "[role=tablist] [role=tab]:nth-child(2)",
        "assertion": "Roles & Access"
      },
      {
        "id": "s6",
        "action": "assertText",
        "targetDescription": "Tab 3 label",
        "locatorHint": "[role=tablist] [role=tab]:nth-child(3)",
        "assertion": "Audit Log"
      },
      {
        "id": "s7",
        "action": "assertSelected",
        "targetDescription": "User Management tab is active",
        "locatorHint": "[role=tab][aria-selected=true]:has-text(\"User Management\")"
      },
      {
        "id": "s8",
        "action": "assertVisible",
        "targetDescription": "User count label",
        "locatorHint": "[data-testid=user-count]"
      },
      {
        "id": "s9",
        "action": "assertContainsText",
        "targetDescription": "\"N Users\" label contains 'Users'",
        "locatorHint": "[data-testid=user-count]",
        "assertion": "Users"
      },
      {
        "id": "s10",
        "action": "assertVisible",
        "targetDescription": "Search input with placeholder",
        "locatorHint": "input[placeholder='Search user']"
      },
      {
        "id": "s11",
        "action": "assertVisible",
        "targetDescription": "Invite user button",
        "locatorHint": "[data-testid=invite-user-btn]"
      },
      {
        "id": "s12",
        "action": "assertContainsText",
        "targetDescription": "Invite user button text",
        "locatorHint": "[data-testid=invite-user-btn]",
        "assertion": "Invite user"
      },
      {
        "id": "s13",
        "action": "assertText",
        "targetDescription": "Column 1 header",
        "locatorHint": "thead th:nth-child(1)",
        "assertion": "User information"
      },
      {
        "id": "s14",
        "action": "assertText",
        "targetDescription": "Column 2 header",
        "locatorHint": "thead th:nth-child(2)",
        "assertion": "Role"
      },
      {
        "id": "s15",
        "action": "assertText",
        "targetDescription": "Column 3 header",
        "locatorHint": "thead th:nth-child(3)",
        "assertion": "Status"
      },
      {
        "id": "s16",
        "action": "assertText",
        "targetDescription": "Column 4 header",
        "locatorHint": "thead th:nth-child(4)",
        "assertion": "Last active"
      },
      {
        "id": "s17",
        "action": "assertText",
        "targetDescription": "Column 5 header",
        "locatorHint": "thead th:nth-child(5)",
        "assertion": "Account Access"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
